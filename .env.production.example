APP_ENV=production
APP_NAME=PrepSync
API_HOST=0.0.0.0
API_PORT=8000

JWT_SECRET_KEY=<set-in-secrets-manager>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=<set-in-secrets-manager>

POSTGRES_HOST=<managed-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DB=prepsync
POSTGRES_USER=<managed-postgres-user>
POSTGRES_PASSWORD=<set-in-secrets-manager>

REDIS_HOST=<managed-redis-host>
REDIS_PORT=6379
